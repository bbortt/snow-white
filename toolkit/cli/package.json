{
  "name": "snow-white",
  "version": "1.0.0",
  "private": true,
  "description": "Snow-White CLI",
  "license": "PolyForm-Small-Business-1.0.0",
  "author": {
    "name": "Timon Borter",
    "email": "timon.borter@gmx.ch"
  },
  "scripts": {
    "build": "run-p build:*",
    "build:dev": "bun build src/index.ts --outdir=target/cli --target=node",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile=target/snow-white-linux-arm64",
    "build:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile=target/snow-white-linux-x64",
    "build:macos-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=target/snow-white-macos-arm64",
    "build:macos-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=target/snow-white-macos-x64",
    "build:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile=target/snow-white-windows-x64.exe",
    "clean": "rimraf ./target",
    "dev": "bun run src/index.ts",
    "lint": "eslint .",
    "lint:fix": "bun run lint -- --fix",
    "prettier:check": "prettier --check \"{,src/**/}*.{cjs,js,mjs,ts,tsx}\"",
    "prettier:format": "prettier --write \"{,src/**/}*.{cjs,js,mjs,ts,tsx}\"",
    "start": "node target/cli/index.js",
    "pretest": "bun run lint",
    "test": "run-p --print-label --race wiremock:start test:bun",
    "test:bun": "run-s --print-label test:wait-for-wiremock test:with-coverage",
    "test:wait-for-wiremock": "wait-on -t 30s http-get://localhost:8080/__admin/health",
    "test:watch": "bun run test:with-coverage --watch",
    "test:with-coverage": "bun test --coverage --isolate",
    "type-check": "tsc --noEmit",
    "wiremock:start": "wiremock --port 8080"
  },
  "dependencies": {
    "@eslint/compat": "2.1.0",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "cosmiconfig": "9.0.2",
    "eslint-plugin-import-x": "4.17.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-regexp": "3.1.1",
    "js-yaml": "5.1.0",
    "undici": "8.5.0"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "@prettier/plugin-xml": "3.4.2",
    "@types/bun": "1.3.14",
    "@types/js-yaml": "4.0.9",
    "@types/node": "26.0.0",
    "@vitest/eslint-plugin": "1.6.20",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-eslint-comments": "3.2.0",
    "eslint-plugin-eslint-plugin": "7.4.0",
    "eslint-plugin-jest": "29.15.3",
    "eslint-plugin-jsdoc": "63.0.9",
    "eslint-plugin-perfectionist": "5.9.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "69.0.0",
    "eslint-webpack-plugin": "6.0.0",
    "globals": "17.7.0",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.5",
    "prettier-plugin-packagejson": "3.0.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "wait-on": "9.0.10",
    "wiremock": "3.13.2",
    "wiremock-captain": "4.1.3"
  },
  "optionalDependencies": {
    "npm-check-updates": "22.2.7"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "cacheDirectories": [
    "node_modules"
  ],
  "licenseUrl": "https://polyformproject.org/licenses/small-business/1.0.0/"
}
